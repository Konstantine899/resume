  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "analyze:scss": "tsx scripts/analyze-scss.ts",
    "analyze:dead-code": "knip --include-files,dependencies,exports",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "lint:styles": "stylelint \"**/*.scss\"",
    "lint:styles:fix": "stylelint \"**/*.scss\" --fix",
    "lint:all": "npm run lint && npm run lint:styles",
    "lint:all:fix": "npm run lint:fix && npm run lint:styles:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run type-check && npm run lint:all",
    "validate:fix": "npm run type-check && npm run lint:all:fix && npm run format",
    "prepare": "husky",
    "mcp:local-files": "npx -y @modelcontextprotocol/server-filesystem@latest D:/Dev/projects D:/Dev/projects/resume",
    "mcp:memory": "npx -y @modelcontextprotocol/server-memory@latest",
    "mcp:context7": "npx -y @upstash/context7-mcp@latest --api-key ctx7sk-5885363f-cc51-420b-9657-2ab63bba8558",
    "mcp:eslint": "npx @eslint/mcp@latest",
    "mcp:all": "concurrently \"npm run mcp:local-files\" \"npm run mcp:memory\" \"npm run mcp:context7\" \"npm run mcp:eslint\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
