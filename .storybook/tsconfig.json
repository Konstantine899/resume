{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "esModuleInterop": true
  },
  "include": [
    "../src/**/*.stories.*",
    "../src/**/*.tsx",
    "../src/**/*.ts",
    "./**/*",
    "../src/vite-env.d.ts"
  ],
  "exclude": ["../src/**/*.test.*", "../src/**/*.spec.*"]
}
