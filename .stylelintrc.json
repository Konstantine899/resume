{
  "extends": ["stylelint-config-standard-scss", "stylelint-config-recess-order"],
  "plugins": ["stylelint-order", "stylelint-scss"],
  "rules": {
    "scss/no-global-function-names": true,
    "scss/double-slash-comment-empty-line-before": "always",
    "scss/comment-no-empty": true,
    "function-url-quotes": "always",
    "number-max-precision": 5,
    "selector-max-class": 3,
    "declaration-block-no-redundant-longhand-properties": true,
    "declaration-no-important": true,
    "unit-allowed-list": [
      "px",
      "%",
      "em",
      "rem",
      "vh",
      "vw",
      "s",
      "ms",
      "deg",
      "fr",
      "vmin",
      "vmax"
    ],
    "alpha-value-notation": "number",
    "color-function-notation": "modern",
    "comment-word-disallowed-list": ["todo", "fixme"],
    "time-min-milliseconds": 100,
    "keyframes-name-pattern": "^[a-z][a-zA-Z0-9-]*$",
    "scss/dollar-variable-colon-space-after": "always",
    "scss/dollar-variable-colon-space-before": "never",
    "scss/dollar-variable-pattern": "^_?[a-z][\\w-]*$",
    "scss/at-mixin-pattern": "^[a-z][\\w-]*$",
    "scss/at-function-pattern": "^[a-z][\\w-]*$",
    "color-hex-length": "short",
    "color-no-invalid-hex": true,
    "font-family-no-duplicate-names": true,
    "function-calc-no-unspaced-operator": true,
    "function-linear-gradient-no-nonstandard-direction": true,
    "selector-max-id": 0,
    "shorthand-property-no-redundant-values": true,
    "declaration-block-no-duplicate-properties": true,
    "declaration-block-no-shorthand-property-overrides": true,
    "block-no-empty": true,
    "no-duplicate-selectors": true,
    "no-empty-source": true,
    "no-invalid-double-slash-comments": true,
    "string-no-newline": true,
    "unit-no-unknown": true,
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "use",
          "forward",
          "include",
          "mixin",
          "function",
          "if",
          "else",
          "return",
          "each",
          "for",
          "while"
        ]
      }
    ],
    "scss/operator-no-unspaced": true,
    "scss/percent-placeholder-pattern": "^[a-z][\\w-]*$",
    "scss/selector-no-redundant-nesting-selector": true,
    "max-nesting-depth": 4
  },
  "overrides": [
    {
      "files": ["**/*.module.scss"],
      "rules": {
        "selector-class-pattern": "^[a-z][\\w-]*$"
      }
    },
    {
      "files": ["**/variables.scss"],
      "rules": {
        "scss/dollar-variable-pattern": "^[a-z][\\w-]*$"
      }
    }
  ],
  "ignoreFiles": ["**/node_modules/**", "**/dist/**", "**/build/**"]
}
